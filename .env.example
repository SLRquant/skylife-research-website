# ---- Firebase (client SDK — these NEXT_PUBLIC_* are safe to ship) ----
# Get these from Firebase Console → Project Settings → Your apps → Web app → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Resend (server only — contact form + newsletter) ----
# https://resend.com/api-keys
RESEND_API_KEY=
# Where contact form submissions go
CONTACT_INBOX=founders@skyliferesearch.com
# "From" address — needs to be a verified Resend domain
CONTACT_FROM=Skylife Research <contact@skyliferesearch.com>
# Optional: Resend audience id for newsletter signups
RESEND_AUDIENCE_ID=
